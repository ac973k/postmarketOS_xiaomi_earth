# Reference: <https://postmarketos.org/devicepkg>
# Maintainer: Daniil Terentev <daniil@terentyeff.ru>
pkgname=device-xiaomi-earth
pkgdesc="Xiaomi Redmi 12C"
pkgver=1
pkgrel=0
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	linux-xiaomi-earth
	mkbootimg
	postmarketos-base
	linux-firmware-mediatek
	firmware-xiaomi-earth
"
makedepends="devicepkg-dev"
source="
	deviceinfo
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	install -d "$pkgdir"/boot/dtbo
	cp "$builddir"/arch/arm64/boot/dts/mediatek/earth.dtbo "$pkgdir"/boot/dtbo/

	devicepkg_package $startdir $pkgname
}

sha512sums="
ef19af5edd66555b5ccf4c079674e8741868197e4d2efc170d97dd96c1b9bdf7d16afab8781eb13a19ba528905ee2ad28b27839026d9f6214702fd0121dd1987  deviceinfo
"
