# Reference: <https://postmarketos.org/vendorkernel>
# Kernel config based on: arch/arm64/configs/earth_defconfig
# Maintainer: Daniil Terentev <daniil@terentyeff.ru>

pkgname=linux-xiaomi-earth
pkgver=4.19.191
pkgrel=0
pkgdesc="Xiaomi Redmi 12C kernel fork"
arch="aarch64"
_carch="arm64"
_flavor="xiaomi-earth"
url="https://kernel.org"
license="GPL-2.0-only"
options="!strip !check !tracedeps pmb:cross-native"
makedepends="
	android-tools
	bash
	bc
	bison
	devicepkg-dev
	findutils
	flex
	gcc
	openssl-dev
	perl
	linux-headers
	musl-dev
	ncurses-dev
	cpio
	coreutils
	xz
	dtc
	binutils
"

# Source
_repository="android_kernel_xiaomi_earth"
_commit="e04db2f50002459af8bab7ba00487d71d6e3936e"
_config="config-$_flavor.$arch"
source="
	$pkgname-$_commit.tar.gz::https://github.com/ac973k/$_repository/archive/$_commit.tar.gz
	$_config
	fix_kernel_genheaders.patch
	fix-broken-inline-functions.patch
	fix-gcc15-inline.patch
"
builddir="$srcdir/$_repository-$_commit"
_outdir="out"

prepare() {
	default_prepare
	REPLACE_GCCH=0 . downstreamkernel_prepare
}

build() {
	unset LDFLAGS
	make -j1 O="$_outdir" ARCH="$_carch" \
		KBUILD_BUILD_VERSION="$((pkgrel + 1 ))-postmarketOS"
}

package() {
	downstreamkernel_package "$builddir" "$pkgdir" "$_carch" \
		"$_flavor" "$_outdir"

	# Install main DTB file manually (avoid overlay issues)
	install -Dm644 "$_outdir"/arch/arm64/boot/dts/mediatek/mt6768.dtb \
		"$pkgdir"/boot/dtbs/mediatek/mt6768.dtb
}

