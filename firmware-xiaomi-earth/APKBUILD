# Maintainer: Daniil Terentev <daniil@terentyeff.ru>
pkgname=firmware-xiaomi-earth
pkgver=1
pkgrel=0
pkgdesc="Proprietary firmware for Xiaomi Redmi 12C (xiaomi-earth)"
arch="noarch"
url="https://github.com/postmarketOS"
license="proprietary"
options="!strip !archcheck !check !spdx !tracedeps pmb:cross-native"
depends="linux-firmware-mediatek"
makedepends=""
source="
	BT_FW.cfg
	WIFI_RAM_CODE_soc1_0_1a_1.bin
	WMT_SOC.cfg
	fm_cust.cfg
	focaltech_mp_fw_djn.ini
	lib3a.ccu
	mt6631_fm_v1_coeff.bin
	mt6631_fm_v1_patch.bin
	soc1_0_patch_mcu_1a_1_hdr.bin
	soc1_0_ram_bt_1a_1_hdr.bin
	soc1_0_ram_mcu_1a_1_hdr.bin
	soc1_0_ram_wifi_1a_1_hdr.bin
	txpowerctrl.cfg
	wifi.cfg
"

package() {
    install -d "$pkgdir"/lib/firmware/postmarketos

    # Config files
    install -m644 "$srcdir"/BT_FW.cfg "$pkgdir"/lib/firmware/postmarketos/
    install -m644 "$srcdir"/WMT_SOC.cfg "$pkgdir"/lib/firmware/postmarketos/
    install -m644 "$srcdir"/fm_cust.cfg "$pkgdir"/lib/firmware/postmarketos/
    install -m644 "$srcdir"/focaltech_mp_fw_djn.ini "$pkgdir"/lib/firmware/postmarketos/
    install -m644 "$srcdir"/txpowerctrl.cfg "$pkgdir"/lib/firmware/postmarketos/
    install -m644 "$srcdir"/wifi.cfg "$pkgdir"/lib/firmware/postmarketos/

    # Firmware binaries
    install -m644 "$srcdir"/WIFI_RAM_CODE_soc1_0_1a_1.bin "$pkgdir"/lib/firmware/postmarketos/
    install -m644 "$srcdir"/mt6631_fm_v1_coeff.bin "$pkgdir"/lib/firmware/postmarketos/
    install -m644 "$srcdir"/mt6631_fm_v1_patch.bin "$pkgdir"/lib/firmware/postmarketos/
    install -m644 "$srcdir"/soc1_0_patch_mcu_1a_1_hdr.bin "$pkgdir"/lib/firmware/postmarketos/
    install -m644 "$srcdir"/soc1_0_ram_bt_1a_1_hdr.bin "$pkgdir"/lib/firmware/postmarketos/
    install -m644 "$srcdir"/soc1_0_ram_mcu_1a_1_hdr.bin "$pkgdir"/lib/firmware/postmarketos/
    install -m644 "$srcdir"/soc1_0_ram_wifi_1a_1_hdr.bin "$pkgdir"/lib/firmware/postmarketos/

    # Camera firmware (executable)
    install -m755 "$srcdir"/lib3a.ccu "$pkgdir"/lib/firmware/postmarketos/
}

